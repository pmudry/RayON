{
    "files.associations": {
        "ostream": "cpp",
        "vector": "cpp",
        "iosfwd": "cpp",
        "limits": "cpp",
        "random": "cpp",
        "algorithm": "cpp",
        "memory": "cpp",
        "type_traits": "cpp",
        "*.cu": "cuda-cpp",
        "*.cuh": "cuda-cpp"
    },
    "C_Cpp.default.intelliSenseMode": "gcc-x64",
    "C_Cpp.default.compilerPath": "/usr/bin/nvcc",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/src/**",
        "/usr/local/cuda/include",
        "/opt/cuda/include"
    ],
    "C_Cpp.default.defines": [
        "__CUDACC__",
        "__NVCC__"
    ]
}