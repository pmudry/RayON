# Simple square-based pyramid
# Vertices
v 0.0 1.0 0.0   # Top
v -1.0 -1.0 1.0 # Front Left
v 1.0 -1.0 1.0  # Front Right
v 1.0 -1.0 -1.0 # Back Right
v -1.0 -1.0 -1.0 # Back Left

# Faces
# Base (2 triangles)
f 2 3 4
f 2 4 5

# Sides (4 triangles)
f 1 2 3 # Front
f 1 3 4 # Right
f 1 4 5 # Back
f 1 5 2 # Left