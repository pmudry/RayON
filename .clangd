CompileFlags:
  Remove:
    - -W*
    - -forward-unknown-to-host-compiler
    - --options-file
    - --options-file=*
    - --generate-code=*
    - -Xcompiler=*
    - --expt-relaxed-constexpr
    - --expt-extended-lambda
    - -rdc=true
    - -rdc
    - --relocatable-device-code=*
    - -t
    - -rdynamic
    - -lineinfo
  Add:
    - --cuda-path=/usr/local/cuda
    - --cuda-gpu-arch=sm_90
    # Explicitly add all include paths so clangd can find headers
    - -I/home/pmudry/git/302_raytracer/src
    - -I/home/pmudry/git/302_raytracer/src/external
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/camera
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/camera/sdl
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/cpu_renderers
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/gpu_renderers
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/gpu_renderers/shaders
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/gpu_renderers/materials
    - -I/home/pmudry/git/302_raytracer/src/302_raytracer/gpu_renderers/materials/legacy
    - -I/usr/local/cuda/include

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: Relaxed
  Suppress:
    - "unknown-cuda-version"
