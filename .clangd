CompileFlags:
  Remove:
    - -W*
    - -forward-unknown-to-host-compiler
    - --options-file
    - --options-file=*
    - --generate-code=*
    - -Xcompiler=*
    - --expt-relaxed-constexpr
    - --expt-extended-lambda
    - -rdc=true
    - -rdc
    - --relocatable-device-code=*
    - -t
    - -rdynamic
    - -lineinfo
    - -maxrregcount*
    - -arch=*
    - --gpu-architecture=*
    - -gencode=*
    - --use_fast_math
  Add:
    - --no-cuda-version-check
    # The include section is automatically generated by cmake at build, do NOT modify.
    - -I/home/pmudry/git/RayON/src
    - -I/home/pmudry/git/RayON/src/external
    - -I/home/pmudry/git/RayON/src/external/imgui
    - -I/home/pmudry/git/RayON/src/rayon
    - -I/home/pmudry/git/RayON/src/rayon/camera
    - -I/home/pmudry/git/RayON/src/rayon/camera/sdl
    - -I/home/pmudry/git/RayON/src/rayon/cpu_renderers
    - -I/home/pmudry/git/RayON/src/rayon/cpu_renderers/cpu_shapes
    - -I/home/pmudry/git/RayON/src/rayon/cpu_renderers/utils
    - -I/home/pmudry/git/RayON/src/rayon/data_structures
    - -I/home/pmudry/git/RayON/src/rayon/gpu_renderers
    - -I/home/pmudry/git/RayON/src/rayon/gpu_renderers/materials
    - -I/home/pmudry/git/RayON/src/rayon/gpu_renderers/materials/legacy
    - -I/home/pmudry/git/RayON/src/rayon/gpu_renderers/optix
    - -I/home/pmudry/git/RayON/src/rayon/gpu_renderers/shaders
    - -I/home/pmudry/git/RayON/src/rayon/render
    - -I/home/pmudry/git/RayON/src/rayon/scenes
    - -I/home/pmudry/Downloads/NVIDIA-OptiX-SDK-9.0.0-linux64-aarch64/include
Diagnostics:
  UnusedIncludes: Strict
  Suppress:
    - "unknown-cuda-version"
    - "drv_unknown_cuda_arch"
Index:
  Background: Build

# OptiX files: define __CUDACC__ so clangd resolves OptixTraversableHandle and
# other OptiX-SDK types hidden behind #ifdef __CUDACC__ guards.
# This section is preserved across CMake regenerations (CMake only rewrites Add:).
---
If:
  PathMatch: src/rayon/gpu_renderers/optix/.*\.(h|hpp|cu|cuh)
CompileFlags:
  Add:
    - -D__CUDACC__
