CompileFlags:
  Remove:
    - -W*
    - -forward-unknown-to-host-compiler
    - --options-file
    - --options-file=*
    - --generate-code=*
    - -Xcompiler=*
    - --expt-relaxed-constexpr
    - --expt-extended-lambda
    - -rdc=true
    - -rdc
    - --relocatable-device-code=*
    - -t
    - -rdynamic
    - -lineinfo
    - -maxrregcount*
  Add:
    - --no-cuda-version-check
    # The include section is automatically generated my cmake at build, do NOT modify.
    - -I/home/jeremy_duc/Documents/RayON/src
    - -I/home/jeremy_duc/Documents/RayON/src/external
    - -I/home/jeremy_duc/Documents/RayON/src/external/imgui
    - -I/home/jeremy_duc/Documents/RayON/src/rayon
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/camera
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/camera/sdl
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/cpu_renderers
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/cpu_renderers/cpu_shapes
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/cpu_renderers/utils
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/data_structures
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/gpu_renderers
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/gpu_renderers/materials
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/gpu_renderers/materials/legacy
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/gpu_renderers/shaders
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/render
    - -I/home/jeremy_duc/Documents/RayON/src/rayon/scenes
Diagnostics:
  UnusedIncludes: Strict
  Suppress:
    - "unknown-cuda-version"
    - "drv_unknown_cuda_arch"
Index:
  Background: Build
